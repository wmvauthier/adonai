      "timing": "would",
      "replacementWindow": true,
      "payload": ["game", "source", "target", "amount", "damageType", "damageAsCost"]
    },
    {
      "id": "damage.dealt",
      "label": { "pt": "Dano causado" },
      "scope": "event",
      "timing": "after",
      "payload": ["game", "source", "target", "amount", "damageType", "damageAsCost"]
    },
    {
      "id": "heal.applied",
      "label": { "pt": "Cura aplicada" },
      "scope": "event",
      "timing": "after",
      "payload": ["game", "source", "target", "amount"]
    },
    {
      "id": "phase.regroup.begin",
      "label": { "pt": "Início da etapa de Reagrupamento" },
      "scope": "phase",
      "timing": "before_expiration",
