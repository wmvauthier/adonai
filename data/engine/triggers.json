{
  "schemaVersion": 1,
  "updatedAt": "2026-06-15",
  "triggers": [
    {
      "id": "game.start",
      "label": { "pt": "Início da partida" },
      "scope": "game",
      "timing": "after",
      "payload": ["game"]
    },
    {
      "id": "turn.begin",
      "label": { "pt": "Início do turno" },
      "scope": "turn",
      "timing": "before",
      "payload": ["game", "playerId", "turnNumber"]
    },
    {
      "id": "turn.end",
      "label": { "pt": "Fim do turno" },
      "scope": "turn",
      "timing": "after",
      "payload": ["game", "playerId", "turnNumber"]
    },
    {
      "id": "phase.prepare.begin",
      "label": { "pt": "Início da etapa de Preparação" },
      "scope": "phase",
      "timing": "before_step_action",
      "payload": ["game", "playerId"]
    },
    {
      "id": "phase.draw.begin",
      "label": { "pt": "Início da etapa de Compra" },
      "scope": "phase",
      "timing": "before_step_action",
      "payload": ["game", "playerId"]
    },
    {
      "id": "phase.draw.amount.replace",
      "label": { "pt": "Modificação da compra automática" },
      "scope": "replacement",
      "timing": "would",
      "replacementWindow": true,
      "payload": ["game", "playerId", "baseAmount", "currentAmount", "reason"]
    },
    {
      "id": "phase.draw.after_auto_draw",
      "label": { "pt": "Depois da compra automática" },
      "scope": "phase",
      "timing": "after_step_action",
      "payload": ["game", "playerId", "drawnCards"]
    },
    {
