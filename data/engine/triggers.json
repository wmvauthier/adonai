      "label": { "pt": "Carta jogada" },
      "scope": "card",
      "timing": "after_announcement",
      "payload": ["game", "playerId", "cardId", "stackObjectId"]
    },
    {
      "id": "card.resolved",
      "label": { "pt": "Carta resolvida" },
      "scope": "card",
      "timing": "after",
      "payload": ["game", "playerId", "cardId", "result"]
    },
    {
      "id": "permanent.enters_battlefield",
      "label": { "pt": "Permanente entra no campo" },
      "scope": "permanent",
      "timing": "after",
      "payload": ["game", "playerId", "instanceUid", "cardId"]
    },
    {
      "id": "permanent.leaves_battlefield",
      "label": { "pt": "Permanente deixa o campo" },
      "scope": "permanent",
      "timing": "after",
      "payload": ["game", "playerId", "instanceUid", "cardId", "destination"]
    },
    {
      "id": "permanent.dies",
      "label": { "pt": "Personagem morre" },
      "scope": "permanent",
      "timing": "after",
      "payload": ["game", "playerId", "instanceUid", "cardId"]
    },
    {
      "id": "moral.changed",
      "label": { "pt": "Virtude ou Desvirtude alterada" },
      "scope": "moral",
      "timing": "after",
      "payload": ["game", "playerId", "changes", "reason"]
    },
    {
      "id": "stack.object_added",
      "label": { "pt": "Objeto colocado na pilha" },
      "scope": "stack",
      "timing": "after",
      "payload": ["game", "stackObject"]
    },
    {
      "id": "stack.object_resolved",
      "label": { "pt": "Objeto da pilha resolvido" },
      "scope": "stack",
      "timing": "after",
      "payload": ["game", "stackObject"]
    },
    {
      "id": "priority.window_opened",
      "label": { "pt": "Janela de prioridade aberta" },
      "scope": "priority",
      "timing": "before",
      "payload": ["game", "playerId", "reason"]
    }
  ]
