      "label": { "pt": "Início da etapa de Consagração" },
      "scope": "phase",
      "timing": "before_step_action",
      "payload": ["game", "playerId"]
    },
    {
      "id": "action.consecrate.after",
      "label": { "pt": "Depois de Consagrar" },
      "scope": "action",
      "timing": "after",
      "payload": ["game", "playerId", "cardId", "cardType"]
    },
    {
      "id": "action.profane.after",
      "label": { "pt": "Depois de Profanar" },
      "scope": "action",
      "timing": "after",
      "payload": ["game", "playerId", "cardId"]
    },
    {
      "id": "phase.preparation.begin",
      "label": { "pt": "Início da etapa de Alistamento" },
      "scope": "phase",
      "timing": "before_priority",
      "payload": ["game", "playerId"]
    },
    {
      "id": "phase.combat.begin",
      "label": { "pt": "Início da etapa de Combate" },
      "scope": "phase",
      "timing": "before_priority",
      "payload": ["game", "playerId"]
    },
    {
      "id": "combat.attackers.declared",
      "label": { "pt": "Atacantes declarados" },
      "scope": "combat",
      "timing": "after",
      "payload": ["game", "attackerId", "attackers", "targets"]
    },
    {
      "id": "combat.attacker.targeted",
      "label": { "pt": "Personagem ou Território escolhido como alvo de ataque" },
      "scope": "combat",
      "timing": "after",
      "payload": ["game", "attackerId", "attackerUid", "target"]
    },
    {
      "id": "combat.blockers.declared",
      "label": { "pt": "Bloqueadores declarados" },
      "scope": "combat",
      "timing": "after",
      "payload": ["game", "defenderId", "blockers"]
    },
    {
      "id": "combat.damage.before",
